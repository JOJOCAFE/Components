{
  "schema": "components.lib.circuit",
  "version": 1,
  "id": "rv8gr_irq_latch",
  "title": "RV8GR IRQ latch and IE flag",
  "source_project": {
    "name": "RV8GR",
    "paths": [
      "/home/jo/kiro/RV8/RV8GR/doc/01_wiring_guide.md",
      "/home/jo/kiro/RV8/RV8GR/doc/labs/lab14_irq_bus.md",
      "/home/jo/kiro/RV8/RV8GR/sim/sim_lab/lab14_irq_bus.py",
      "/home/jo/kiro/RV8/RV8GR/Kicad/gen_kicad.py"
    ]
  },
  "purpose": "Prove the RV8GR v1.0 polling interrupt latch without adding a hardware vector, acknowledge, or PC force path.",
  "chips": [
    {"ref": "U31", "part": "74HC74", "role": "Dual D flip-flop: IE flag and IRQ_FF latch"},
    {"ref": "U33", "part": "74HC21", "role": "EI_decode generator feeding U31 CLK1"}
  ],
  "ports": [
    {"name": "/RST", "direction": "input", "active_low": true},
    {"name": "EI_decode", "direction": "input", "edge": "rising"},
    {"name": "/IRQ", "direction": "input", "active_low": true, "edge": "rising release"},
    {"name": "IE", "direction": "output"},
    {"name": "IRQ_FF", "direction": "output"},
    {"name": "PC_FORCE", "direction": "absent", "description": "v1.0 has no hardware PC force or vector path."},
    {"name": "IRQ_ACK", "direction": "absent", "description": "v1.0 clears IRQ_FF only with /RST."}
  ],
  "wiring": [
    {"net": "/RST", "connections": ["U31.1", "U31.13"]},
    {"net": "IE_D", "connections": ["U31.2", "VCC"]},
    {"net": "EI_decode", "connections": ["U33.8", "U31.3"]},
    {"net": "IE", "connections": ["U31.5"]},
    {"net": "IRQ_D", "connections": ["U31.12", "VCC"]},
    {"net": "/IRQ", "connections": ["U31.11"]},
    {"net": "IRQ_FF", "connections": ["U31.9"]},
    {"net": "VCC", "connections": ["U31.4", "U31.10", "U31.14"]},
    {"net": "GND", "connections": ["U31.7"]}
  ],
  "behavior": {
    "reset": "/RST LOW clears IE and IRQ_FF to 0.",
    "ei": "EI_decode rising edge clocks D=1 into IE.",
    "di": "DI has no v1.0 hardware effect; IE clears only via /RST.",
    "irq": "/IRQ asserted LOW does not latch; release back HIGH creates the rising edge that latches IRQ_FF=1.",
    "sticky": "IRQ_FF remains set until /RST in v1.0.",
    "polling_only": "IE and IRQ_FF are software-visible/polling flags only; no PC auto-jump, no vector, no acknowledge clear."
  },
  "timing": {
    "clocking": "edge_sensitive",
    "trigger_edges": ["EI_decode rising sets IE", "/IRQ rising release sets IRQ_FF"],
    "non_trigger_edge": "/IRQ low assertion alone holds IRQ_FF",
    "paths": [
      {"name": "ei_to_ie", "from": "EI_decode", "to": "IE", "when": "rising edge", "source_part": "74HC74"},
      {"name": "irq_release_to_irq_ff", "from": "/IRQ", "to": "IRQ_FF", "when": "rising release", "source_part": "74HC74"},
      {"name": "reset_clear", "from": "/RST", "to": "IE and IRQ_FF", "when": "LOW", "source_part": "74HC74"}
    ]
  },
  "verification": {
    "tests": ["tests/irq_latch.json"],
    "guarantees": [
      "/RST clears IE and IRQ_FF",
      "EI_decode rising edge sets IE",
      "/IRQ low assertion alone does not latch IRQ_FF",
      "/IRQ release rising edge latches IRQ_FF",
      "IRQ_FF is sticky until /RST",
      "v1.0 has no PC force, vector, IRQ_ack, or auto-clear"
    ]
  },
  "audience": "students ages 10-15, still useful for older learners"
}
