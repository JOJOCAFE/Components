{
  "schema": "components.lib.circuit.test.whole_system_chip_level_virtual",
  "version": 1,
  "circuit": "rv8gr_whole_system_chip_level_virtual",
  "source": "Lib/Circuits/RV8GR_WholeSystemChipLevelVirtual/circuit.json",
  "chip_bench_plan": {
    "source": "../RV8/RV8GR/doc/rv8gr_virtual_bench_plan.json",
    "expect_chip_count": 18,
    "expect_split_records_per_chip": 5,
    "expect_total_split_record_mappings": 90,
    "required_instruments": ["InputSource", "ClockSource", "Switch", "Probe", "BusProbe", "OutputAssert", "RCParasitic", "DelayNoise"]
  },
  "included_packages": [
    {"package": "RV8GR_BootSequenceTrace", "source": "Lib/Circuits/RV8GR_BootSequenceTrace/tests/boot_sequence_trace.json", "expect_final": {"PC": "0x0006", "DP": "0x80", "PG": "0x00", "AC": "0x00", "Z": 1}},
    {"package": "RV8GR_Lab13MarkerTrace", "source": "Lib/Circuits/RV8GR_Lab13MarkerTrace/tests/lab13_marker_trace.json", "expect_final": {"PC": "0x000E", "DP": "0x80", "PG": "0x00", "AC": "0xAA", "Z": 0}},
    {"package": "RV8GR_StoreLoadBranchTrace", "source": "Lib/Circuits/RV8GR_StoreLoadBranchTrace/tests/store_load_branch_trace.json", "expect_coverage": ["SB", "LB", "BEQ"]},
    {"package": "RV8GR_PageJumpTrace", "source": "Lib/Circuits/RV8GR_PageJumpTrace/tests/page_jump_trace.json", "expect_coverage": ["SETDP", "SETPG", "J"]},
    {"package": "RV8GR_InterruptTrace", "source": "Lib/Circuits/RV8GR_InterruptTrace/tests/interrupt_trace.json", "expect_coverage": ["EI", "DI", "IRQ_LOW", "IRQ_RELEASE"]},
    {"package": "RV8GR_BusOwnership", "source": "Lib/Circuits/RV8GR_BusOwnership/tests/bus_ownership.json", "expect_coverage": ["IBUS", "DBUS", "forced_conflict"]}
  ],
  "stress_profiles": [
    {"net": "CLK", "instruments": ["RCParasitic", "DelayNoise", "OutputAssert"], "delay_profile": "breadboard_slow_edge_estimate", "claim": "virtual_stress_only"},
    {"net": "/RST", "instruments": ["RCParasitic", "DelayNoise", "OutputAssert"], "delay_profile": "weak_pull_reset_net", "claim": "virtual_stress_only"},
    {"net": "IBUS[0]", "instruments": ["BusProbe", "RCParasitic", "DelayNoise", "OutputAssert"], "delay_profile": "long_bus_net_with_probe", "claim": "virtual_stress_only"},
    {"net": "DBUS[0]", "instruments": ["BusProbe", "RCParasitic", "DelayNoise", "OutputAssert"], "delay_profile": "long_bus_net_with_probe", "claim": "virtual_stress_only"},
    {"net": "RAM_/OE", "instruments": ["Probe", "DelayNoise", "OutputAssert"], "delay_profile": "control_line_glitch_stress", "claim": "virtual_stress_only"},
    {"net": "RAM_/WE", "instruments": ["Probe", "DelayNoise", "OutputAssert"], "delay_profile": "control_line_glitch_stress", "claim": "virtual_stress_only"},
    {"net": "ROM_/OE", "instruments": ["Probe", "DelayNoise", "OutputAssert"], "delay_profile": "control_line_glitch_stress", "claim": "virtual_stress_only"}
  ],
  "system_sequences": [
    {"name": "boot_manual_12_edges", "package": "RV8GR_BootSequenceTrace", "clock_edges": 12, "expect_pass": true},
    {"name": "lab13_marker_15_edges", "package": "RV8GR_Lab13MarkerTrace", "clock_edges": 15, "expect_pass": true},
    {"name": "ram_store_load_branch", "package": "RV8GR_StoreLoadBranchTrace", "expect_pass": true},
    {"name": "page_jump", "package": "RV8GR_PageJumpTrace", "expect_pass": true},
    {"name": "irq_latch_polling_boundary", "package": "RV8GR_InterruptTrace", "expect_pass": true}
  ],
  "ai_error_trap_tests": [
    {
      "id": "pin_number_truth",
      "problem": "AI may use the wrong physical pin number or pin name.",
      "virtual_test": "Before circuit/system simulation, compare every referenced chip pin number, pin name, direction, and active-low marker against the DB definition and pinout evidence.",
      "must_fail_when": ["pin_number_mismatch", "pin_name_mismatch", "direction_mismatch", "active_low_missing"],
      "fix_method": "Fix the chip definition or source-backed pin mapping first; do not hide the error by moving circuit wires."
    },
    {
      "id": "output_output_bus_contention",
      "problem": "AI may connect output to output with no valid bus condition.",
      "virtual_test": "Allow output-to-input directly. Allow multiple outputs only on a named bus when enable conditions prove at most one driver is active; force a conflict vector with BusProbe.",
      "must_fail_when": ["two_outputs_always_enabled", "missing_oe_condition", "forced_conflict_not_reported"],
      "fix_method": "Add tri-state control, buffer/transceiver direction, or OE sequencing so the old driver is off before the new driver is enabled."
    },
    {
      "id": "edge_polarity",
      "problem": "AI may use positive/negative or rising/falling edge behavior incorrectly.",
      "virtual_test": "For every edge-triggered chip, assert the declared trigger edge captures and the opposite edge holds; reset/load priority must be explicit.",
      "must_fail_when": ["rising_edge_expected_but_falling_used", "falling_edge_expected_but_rising_used", "opposite_edge_changes_state"],
      "fix_method": "Move the signal to the correct clock phase or add an intentional inverter; keep the test expectation tied to the datasheet edge."
    },
    {
      "id": "propagation_delay_deadband",
      "problem": "Propagation delay can make a new bus driver enable before the old one is high-Z.",
      "virtual_test": "Apply RCParasitic and DelayNoise on CLK, /RST, IBUS, DBUS, /OE, and /WE; assert output-disable-to-Z plus enable delay leaves positive deadband.",
      "must_fail_when": ["negative_bus_deadband", "delayed_oe_overlap", "destination_sample_before_settle"],
      "fix_method": "Add phase separation, delay the new enable, disable the old driver earlier, shorten or buffer the net, or lower the clock rate until measured margin is positive."
    }
  ],
  "claim_boundary": {
    "status": "virtual_whole_system_not_physical_signoff",
    "blocked_physical_claims": ["hardware_1mhz_ready", "hardware_2mhz_ready", "hardware_5mhz_ready", "student_build_speed_recommendation"],
    "required_next_physical_evidence": ["installed memory markings", "voltage sweep", "clock/reset scope captures", "bus deadband", "memory float timing", "breadboard RC calibration"]
  }
}
