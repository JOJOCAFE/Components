use standard.digital as digital;
use standard.virtual as virtual;

component:component BoardV2NotGate is components.digital {
  device Clock, virtual.ClockSource;
  device U1, digital.74HC04;
  device Observe, virtual.Probe;

  net clock : digital;
  net inverted : digital;

  connect Clock.CLK -> clock;
  connect clock -> U1.1A;
  connect U1.1Y -> inverted;
  connect inverted -> Observe.IN;

  probe inverted_level, inverted;
  display inverted_level as value, { "label": "inverted output" };
}
