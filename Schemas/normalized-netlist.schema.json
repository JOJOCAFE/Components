{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jojocafe.github.io/Components/Schemas/normalized-netlist.schema.json",
  "title": "Components normalized netlist",
  "description": "Machine-readable contract for Design.to_netlist() exports. The schema is intentionally additive: current consumers should ignore unknown fields and require only fields emitted by the exporter today.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "format",
    "version",
    "name",
    "design",
    "chips",
    "nets",
    "validation",
    "board_errors"
  ],
  "properties": {
    "format": {
      "const": "chiplib.netlist",
      "description": "Stable artifact family identifier."
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema/export contract version. Version 1 is the current additive normalized-netlist format."
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "design": {
      "type": "object",
      "additionalProperties": true,
      "description": "Canonical schematic JSON retained for lossless Design.from_netlist() round trips."
    },
    "chips": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/chip"
      },
      "description": "Physical component instances sorted by reference designator."
    },
    "instances": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/chip"
      },
      "description": "Reserved alias for future consumers that use instance terminology; current exports use chips."
    },
    "buses": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bus"
      }
    },
    "rails": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rail"
      }
    },
    "nets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/net"
      },
      "description": "Resolved electrical nets sorted by stable net name."
    },
    "connections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/connection"
      },
      "description": "Source schematic connection rules with normalized endpoint references."
    },
    "pullups": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pulldowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "input_sets": {
      "type": "object",
      "additionalProperties": true
    },
    "clocks": {
      "type": "object",
      "additionalProperties": true
    },
    "probes": {
      "type": "object",
      "additionalProperties": true
    },
    "displays": {
      "type": "object",
      "additionalProperties": true
    },
    "expect": {
      "type": "object",
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "$ref": "#/$defs/report"
    },
    "board_errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/issue"
      }
    }
  },
  "$defs": {
    "logic": {
      "enum": [0, 1, "Z", "X"]
    },
    "chip": {
      "type": "object",
      "additionalProperties": true,
      "required": ["ref", "part", "pins"],
      "properties": {
        "ref": {
          "type": "string",
          "minLength": 1,
          "description": "Stable instance id/reference designator, for example U1."
        },
        "id": {
          "type": "string",
          "description": "Optional future stable id. If omitted, consumers should use ref as the stable instance id."
        },
        "part": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "module": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/status",
          "description": "Optional component status metadata copied from the component DB when present."
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "pins": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/chipPin"
          }
        }
      }
    },
    "status": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "properties": {
        "datasheet": {"type": "string"},
        "pinout": {"type": "string"},
        "python_behavior": {"type": "string"},
        "verilog_model": {"type": "string"},
        "verilog_export": {"type": "string"},
        "tests": {"type": "string"}
      }
    },
    "chipPin": {
      "type": "object",
      "additionalProperties": true,
      "required": ["number", "name", "direction", "active_low"],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "$ref": "#/$defs/pinDirection"
        },
        "active_low": {
          "type": "boolean"
        },
        "net": {
          "type": ["string", "null"]
        },
        "value": {
          "$ref": "#/$defs/logic"
        }
      }
    },
    "pinEndpoint": {
      "type": "object",
      "additionalProperties": true,
      "required": ["chip", "pin", "name", "direction", "ref"],
      "properties": {
        "chip": {
          "type": "string",
          "minLength": 1
        },
        "pin": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "$ref": "#/$defs/pinDirection"
        },
        "ref": {
          "type": "string",
          "pattern": "^[^:]+:[0-9]+$",
          "description": "Stable pin reference in chip:pin-number form."
        }
      }
    },
    "pinDirection": {
      "type": "string",
      "description": "Physical/simulator pin direction. Current netlist endpoints use in/out/bidir/power/nc; DB-derived future pins may use input/output/bidirectional aliases.",
      "enum": [
        "in",
        "out",
        "bidir",
        "power",
        "nc",
        "input",
        "output",
        "bidirectional",
        "unknown"
      ]
    },
    "bus": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "width"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "rail": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "value"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "$ref": "#/$defs/logic"
        }
      }
    },
    "net": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "kind", "value", "pins", "pulls", "sources"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Stable net id. Bus line nets use bus:NAME[INDEX]."
        },
        "id": {
          "type": "string",
          "description": "Optional future stable id. If omitted, consumers should use name as the stable net id."
        },
        "kind": {
          "enum": ["net", "bus"]
        },
        "bus": {
          "type": ["string", "null"],
          "description": "Bus name for kind=bus; null for scalar nets."
        },
        "index": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Bus bit index for kind=bus; null for scalar nets."
        },
        "value": {
          "$ref": "#/$defs/logic"
        },
        "pins": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pinEndpoint"
          }
        },
        "pulls": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pull"
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source"
          },
          "description": "Manual, rail, input, or link drivers attached to the net. Enabled non-Z sources are electrical drivers."
        }
      }
    },
    "pull": {
      "type": "object",
      "additionalProperties": true,
      "required": ["source", "value"],
      "properties": {
        "source": {
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/logic"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "value", "enabled"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "$ref": "#/$defs/logic"
        },
        "enabled": {
          "type": "boolean"
        },
        "direction": {
          "enum": ["source", "destination", "bidirectional", "unknown"],
          "description": "Optional future netlist-role metadata. Current exports infer destinations from pin directions and drivers from sources."
        }
      }
    },
    "connection": {
      "type": "object",
      "additionalProperties": true,
      "required": ["rule", "endpoints"],
      "properties": {
        "rule": {
          "type": "string"
        },
        "endpoints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/endpoint"
          }
        }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": true,
      "required": ["ref", "kind", "target"],
      "properties": {
        "ref": {
          "type": "string"
        },
        "kind": {
          "enum": ["pin", "bus", "net", "rail", "alias"]
        },
        "target": {
          "type": "string"
        },
        "chip": {
          "type": "string"
        },
        "pin": {
          "type": ["integer", "string"]
        },
        "bus": {
          "type": "string"
        },
        "index": {
          "type": "integer",
          "minimum": 0
        },
        "rail": {
          "type": "string"
        },
        "direction": {
          "enum": ["source", "destination", "bidirectional", "unknown"],
          "description": "Optional future source/destination role for directed importers. Current connect rules are electrical joins, not ordered data-flow edges."
        }
      }
    },
    "report": {
      "type": "object",
      "additionalProperties": true,
      "required": ["ok", "errors", "warnings"],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/issue"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/issue"
          }
        }
      }
    },
    "issue": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        }
      }
    }
  }
}
