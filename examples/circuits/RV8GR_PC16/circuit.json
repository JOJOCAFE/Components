{
  "schema": "components.lib.circuit",
  "version": 1,
  "id": "rv8gr_pc16",
  "title": "RV8GR 16-bit program counter",
  "source_project": {
    "name": "RV8GR",
    "paths": [
      "/home/jo/kiro/RV8/RV8GR/doc/labs/lab03_pc_counter.md",
      "/home/jo/kiro/RV8/RV8GR/doc/labs/lab10_branch_jump.md",
      "/home/jo/kiro/RV8/RV8GR/doc/labs/lab13_full_system.md",
      "/home/jo/kiro/RV8/RV8GR/doc/build_plan/01_student_incremental_build_plan.md",
      "/home/jo/kiro/RV8/RV8GR/doc/01_wiring_guide.md",
      "/home/jo/kiro/RV8/RV8GR/rtl/rv8gr_chip_level.v"
    ]
  },
  "purpose": "Hold, increment, or parallel-load the RV8GR 16-bit program counter.",
  "chips": [
    {"ref": "U1", "part": "74HC161", "role": "PC bits 0-3"},
    {"ref": "U2", "part": "74HC161", "role": "PC bits 4-7"},
    {"ref": "U3", "part": "74HC161", "role": "PC bits 8-11"},
    {"ref": "U4", "part": "74HC161", "role": "PC bits 12-15"}
  ],
  "ports": [
    {"name": "CLK", "direction": "input", "edge": "rising"},
    {"name": "/RST", "direction": "input", "active_low": true},
    {"name": "/PC_LD", "direction": "input", "active_low": true},
    {"name": "PC_INC", "direction": "input"},
    {"name": "IRL0..IRL7", "direction": "input", "description": "Low byte loaded into PC[7:0]."},
    {"name": "PG0..PG7", "direction": "input", "description": "High byte loaded into PC[15:8]."},
    {"name": "PC0..PC15", "direction": "output"},
    {"name": "RCO0..RCO2", "direction": "internal"}
  ],
  "wiring": [
    {"net": "VCC", "connections": ["VCC", "U1.16", "U2.16", "U3.16", "U4.16"], "description": "Documented 74HC161 positive supply rail."},
    {"net": "GND", "connections": ["GND", "U1.8", "U2.8", "U3.8", "U4.8"], "description": "Documented 74HC161 ground rail."},
    {"net": "CLK", "connections": ["U1.2", "U2.2", "U3.2", "U4.2"]},
    {"net": "/RST", "connections": ["U1.1", "U2.1", "U3.1", "U4.1"]},
    {"net": "/PC_LD", "connections": ["U1.9", "U2.9", "U3.9", "U4.9"]},
    {"net": "PC_INC", "connections": ["U1.7", "U1.10", "U2.7", "U3.7", "U4.7"]},
    {"net": "RCO0", "connections": ["U1.15", "U2.10"]},
    {"net": "RCO1", "connections": ["U2.15", "U3.10"]},
    {"net": "RCO2", "connections": ["U3.15", "U4.10"]},
    {"net": "IRL0..IRL7", "connections": ["U1.3", "U1.4", "U1.5", "U1.6", "U2.3", "U2.4", "U2.5", "U2.6", "IRL0..IRL7"]},
    {"net": "PG0..PG7", "connections": ["U3.3", "U3.4", "U3.5", "U3.6", "U4.3", "U4.4", "U4.5", "U4.6", "PG0..PG7"]},
    {"net": "PC0..PC15", "connections": ["U1.14", "U1.13", "U1.12", "U1.11", "U2.14", "U2.13", "U2.12", "U2.11", "U3.14", "U3.13", "U3.12", "U3.11", "U4.14", "U4.13", "U4.12", "U4.11", "PC0..PC15"]}
  ],
  "behavior": {
    "reset": "/RST LOW asynchronously clears PC to 0x0000.",
    "count": "When /RST=1, /PC_LD=1, and PC_INC=1, each rising clock increments PC by one.",
    "hold": "When /RST=1, /PC_LD=1, and PC_INC=0, rising clocks hold PC.",
    "load": "When /RST=1 and /PC_LD=0, the next rising clock loads PC={PG,IRL}.",
    "priority": ["/RST", "/PC_LD", "count when PC_INC=1", "hold"],
    "cascade": "U1 RCO enables U2 ENT; U2 RCO enables U3 ENT; U3 RCO enables U4 ENT."
  },
  "timing": {
    "clocking": "edge_sensitive",
    "trigger_edge": "rising",
    "non_trigger_edge": "falling_or_no_rising_edge_holds_state",
    "paths": [
      {"name": "clock_to_pc", "from": "CLK", "to": "PC0..PC15", "source_part": "74HC161"},
      {"name": "rco_cascade", "from": "U1/U2/U3 terminal count", "to": "next nibble ENT", "source_part": "74HC161"},
      {"name": "parallel_load", "from": "IRL/PG inputs", "to": "PC outputs on rising CLK when /PC_LD=0", "source_part": "74HC161"}
    ]
  },
  "verification": {
    "tests": ["tests/pc16.json"],
    "guarantees": [
      "asynchronous reset to zero",
      "rising-edge count",
      "no-edge hold",
      "PC_INC gated hold",
      "RCO carry chain across U1-U4",
      "parallel load of {PG,IRL}",
      "/PC_LD priority over count"
    ]
  },
  "audience": "students ages 10-15, still useful for older learners"
}
