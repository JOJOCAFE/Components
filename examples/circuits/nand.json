{
  "name": "nand",
  "description": "Single 74HC00 NAND gate with switch inputs and a logic probe.",
  "chips": {
    "U1": {"part": "74HC00", "label": "NAND"}
  },
  "aliases": {
    "A": "U1:1",
    "B": "U1:2",
    "Y": "U1:3"
  },
  "connect": [
    "VCC -> U1:14",
    "GND -> U1:7"
  ],
  "inputs": {
    "power_on": ["A = 1", "B = 1"]
  },
  "input_sets": {
    "front_panel": {
      "channels": [
        {"index": 0, "name": "SW_A", "to": "A", "initial": 1},
        {"index": 1, "name": "SW_B", "to": "B", "initial": 1}
      ]
    }
  },
  "probes": {
    "logic": [
      {"name": "nand_y", "target": "Y"}
    ]
  },
  "steps": ["apply power_on", "settle", "probe"]
}
