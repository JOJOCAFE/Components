{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jojocafe.github.io/Components/lib/standard/compact.component.schema.json",
  "title": "Components compact component envelope",
  "$comment": "Shared human-authored envelope. A typed schema selects the payload contract; this file is not an active package definition.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "version", "profile", "part", "about", "package", "pins", "simulation", "ui"],
  "properties": {
    "schema": {"type": "string", "pattern": "^db\\.component\\.(passive|virtual|discrete|support)\\.compact$"},
    "version": {"const": "0.2"},
    "profile": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*@[0-9]+\\.[0-9]+$"},
    "part": {"type": "string", "minLength": 1},
    "about": {"type": "object", "additionalProperties": false, "required": ["title", "family", "group", "kind", "role"], "properties": {"title": {"type": "string", "minLength": 1}, "family": {"type": "string", "minLength": 1}, "group": {"enum": ["passive", "virtual", "discrete", "support"]}, "kind": {"type": "string", "minLength": 1}, "role": {"type": "string", "minLength": 1}}},
    "package": {"type": "object", "additionalProperties": false, "required": ["kind"], "properties": {"kind": {"type": "string", "minLength": 1}, "default": {"type": "string", "minLength": 1}}},
    "pins": {"type": "object", "minProperties": 1, "propertyNames": {"pattern": "^[1-9][0-9]*$"}, "additionalProperties": {"$ref": "#/$defs/pin"}},
    "simulation": {"type": "object", "minProperties": 1, "required": ["service"], "properties": {"service": {"type": "string", "minLength": 1}}, "additionalProperties": true},
    "ui": {"type": "object", "minProperties": 1, "required": ["symbol"], "properties": {"symbol": {"type": "string", "minLength": 1}}, "additionalProperties": true},
    "sources": {"type": "array", "items": {"type": "object", "required": ["label", "url"], "properties": {"label": {"type": "string"}, "url": {"type": "string"}}, "additionalProperties": true}},
    "known_limitations": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "passive": {"type": "object"},
    "virtual": {"type": "object"},
    "discrete": {"type": "object"},
    "support": {"type": "object"}
  },
  "$defs": {
    "pin": {"type": "array", "minItems": 2, "maxItems": 3, "prefixItems": [{"type": "string", "minLength": 1}, {"enum": ["in", "out", "io", "passive", "power", "nc"]}, {"type": "object", "additionalProperties": false, "properties": {"rail": {"enum": ["VCC", "VDD", "GND", "VSS"]}, "active": {"const": "low"}, "function": {"type": "string"}}}], "items": false}
  }
}
