{
  "name": "tiny_cpu_slice",
  "description": "Small CPU-style slice: counter address lines feeding SRAM address pins plus NAND control.",
  "chips": {
    "U1": {"part": "74HC161", "label": "PC"},
    "U2": {"part": "62256", "label": "RAM"},
    "U3": {"part": "74HC00", "label": "CTRL"}
  },
  "buses": {
    "ADDR": {"width": 15},
    "DATA": {"width": 8}
  },
  "aliases": {
    "CLK": "U1:2",
    "PC0": "U1:14",
    "PC1": "U1:13",
    "RAM_D0": "U2:11",
    "CTRL_Y": "U3:3"
  },
  "connect": [
    "VCC -> U1:16, U2:28, U3:14",
    "GND -> U1:8, U2:14, U3:7",
    "PC0 -> ADDR:0",
    "PC1 -> ADDR:1",
    "U2:10 -> ADDR:0",
    "U2:9 -> ADDR:1",
    "U2:8 -> ADDR:2",
    "U2:7 -> ADDR:3",
    "U2:6 -> ADDR:4",
    "U2:5 -> ADDR:5",
    "U2:4 -> ADDR:6",
    "U2:3 -> ADDR:7",
    "U2:25 -> ADDR:8",
    "U2:24 -> ADDR:9",
    "U2:21 -> ADDR:10",
    "U2:23 -> ADDR:11",
    "U2:2 -> ADDR:12",
    "U2:26 -> ADDR:13",
    "U2:1 -> ADDR:14",
    "RAM_D0 -> DATA:0",
    "U3:1 -> ADDR:0",
    "U3:2 -> DATA:0"
  ],
  "inputs": {
    "reset_read": [
      "U1:1 = 1",
      "U1:9 = 1",
      "U1:7 = 1",
      "U1:10 = 1",
      "U1:3 = 0",
      "U1:4 = 0",
      "U1:5 = 0",
      "U1:6 = 0",
      "CLK = 0",
      "U2:20 = 0",
      "U2:22 = 0",
      "U2:27 = 1"
    ]
  },
  "clocks": {
    "main": {"to": "CLK", "period_ns": 100, "initial": 0}
  },
  "probes": {
    "slice": ["PC0", "PC1", "DATA:0", "CTRL_Y"]
  },
  "steps": ["apply reset_read", "settle", "clock main pulse 20ns", "probe"]
}
