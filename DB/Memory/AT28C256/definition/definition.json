  "logic": {
    "type": "parallel_eeprom",
    "address_width": 15,
    "data_width": 8,
    "read": {
      "when": "/CE=0 and /OE=0 and /WE=1",
      "drive": "DQ"
    },
    "write": {
      "when": "/CE=0 and /OE=1 during a valid /WE-low write window",
      "latch": "/WE rising edge",
      "sample": "DQ",
      "address_sample": "A",
      "fidelity_level": "timed_functional",
      "busy_behavior": "write_cycle_updates blocks functional readback for the configured simulator update count; full data polling is not modeled in v0.1"
    },
    "tristate": {
      "when": "not read",
      "DQ": "Z"
    }
  },
