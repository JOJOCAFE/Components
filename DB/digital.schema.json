{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jojocafe.github.io/Components/DB/digital.schema.json",
  "title": "Components DB digital component definition",
  "$comment": "Chip model frozen at v0.1 on 2026-07-09.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "version",
    "part",
    "metadata",
    "package",
    "pins",
    "logic",
    "timing",
    "generation",
    "verification",
    "datasheet"
  ],
  "properties": {
    "schema": {
      "const": "db.component.digital"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "part": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["title", "family", "group", "role"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "family": {"type": "string", "minLength": 1},
        "group": {"enum": ["74xx", "memory"]},
        "role": {"type": "string", "minLength": 1}
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "pins"],
      "properties": {
        "kind": {"type": "string", "minLength": 1},
        "pins": {"type": "integer", "minimum": 1},
        "default": {"type": "string"}
      }
    },
    "pins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["number", "name", "direction"],
        "properties": {
          "number": {"type": "integer", "minimum": 1},
          "name": {"type": "string", "minLength": 1},
          "direction": {"$ref": "#/$defs/pinDirection"},
          "active_low": {"type": "boolean"},
          "rail": {"enum": ["VCC", "VDD", "GND", "VSS"]},
          "bus": {"type": "string", "minLength": 1},
          "bit": {"type": "integer", "minimum": 0},
          "clock": {"type": "boolean"},
          "function": {"type": "string", "minLength": 1}
        }
      }
    },
    "logic": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type"],
      "properties": {
        "type": {"type": "string", "minLength": 1},
        "width": {"type": "integer", "minimum": 1}
      }
    },
    "timing": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "delay_ns": {"type": "integer", "minimum": 0},
        "clock_edge": {"enum": ["rising", "falling"]}
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": true,
      "required": ["targets", "python", "verilog"],
      "properties": {
        "targets": {
          "type": "array",
          "items": {"$ref": "#/$defs/generationTarget"},
          "uniqueItems": true
        },
        "python": {
          "type": "object",
          "additionalProperties": true,
          "required": ["factory", "part"],
          "properties": {
            "factory": {"type": "string", "minLength": 1},
            "part": {"type": "string", "minLength": 1}
          }
        },
        "verilog": {
          "type": "object",
          "additionalProperties": true,
          "required": ["module", "file"],
          "properties": {
            "module": {"type": "string", "minLength": 1},
            "file": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": true,
      "required": ["tests", "required_vectors"],
      "properties": {
        "tests": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/testType"},
          "uniqueItems": true
        },
        "required_vectors": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "datasheet": {
      "type": "object",
      "additionalProperties": true,
      "required": ["sources"],
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
          "type": "object",
          "additionalProperties": true,
          "required": ["label", "package_evidence"],
          "anyOf": [
            {"required": ["url"]},
            {"required": ["file"]}
          ],
          "properties": {
            "label": {"type": "string", "minLength": 1},
            "url": {"type": "string", "minLength": 1},
            "file": {"type": "string", "minLength": 1},
            "package_evidence": {"type": "string", "minLength": 1}
          }
        }
        }
      }
    },
    "status": {
      "type": "object",
      "additionalProperties": {"type": "string"},
      "required": [
        "datasheet",
        "pinout",
        "python_behavior",
        "verilog_model",
        "verilog_export",
        "tests"
      ],
      "properties": {
        "datasheet": {"$ref": "#/$defs/statusValue"},
        "pinout": {"$ref": "#/$defs/statusValue"},
        "python_behavior": {"$ref": "#/$defs/statusValue"},
        "verilog_model": {"$ref": "#/$defs/statusValue"},
        "verilog_export": {"$ref": "#/$defs/statusValue"},
        "tests": {"$ref": "#/$defs/statusValue"}
      }
    },
    "definition_layers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component", "package", "pins", "power", "logic", "timing", "electrical"],
      "properties": {
        "component": {"$ref": "#/$defs/definitionLayer"},
        "package": {"$ref": "#/$defs/definitionLayer"},
        "pins": {"$ref": "#/$defs/definitionLayer"},
        "power": {"$ref": "#/$defs/definitionLayer"},
        "logic": {"$ref": "#/$defs/definitionLayer"},
        "timing": {"$ref": "#/$defs/definitionLayer"},
        "electrical": {"$ref": "#/$defs/definitionLayer"}
      }
    }
  },
  "$defs": {
    "definitionLayer": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema", "version", "part"],
      "properties": {
        "schema": {"type": "string", "minLength": 1},
        "version": {"type": "integer", "minimum": 1},
        "part": {"type": "string", "minLength": 1}
      }
    },
    "statusValue": {
      "enum": ["verified", "modeled", "tested", "missing", "blocked", "unknown", "not_applicable"]
    },
    "pinDirection": {
      "enum": ["input", "output", "bidirectional", "passive", "power", "nc", "unknown"]
    },
    "generationTarget": {
      "enum": [
        "json",
        "python_simulator",
        "verilog_wrapper",
        "verilog_testbench",
        "kicad_symbol",
        "svg_pinout",
        "documentation",
        "unit_test",
        "interactive_demo"
      ]
    },
    "testType": {
      "enum": ["truth_table", "timing", "tri_state", "bus_fight", "propagation"]
    }
  }
}
